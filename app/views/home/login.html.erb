<!-- ct — login view -->

<!-- Login Modal -->
<div id="login-overlay">
    <div id="login-box">
        <h1 id="login-title">🐱 welcome to ct web 🐱</h1>
        <p class="login-sub">the cat zone awaits you...</p>
        <label for="login-user">whats your name human?</label>
        <input
            type="text"
            id="login-user"
            placeholder="type your name..."
            autocomplete="username"
        >
        <label for="login-email">whats your email?</label>
        <input
            type="email"
            id="login-email"
            placeholder="your email..."
            autocomplete="email"
        >

        <div class="login-check">
            <input type="checkbox" id="cat-learn-check" value="script">
            <label for="cat-learn-check" class="check-label">I want to learn about cats 😺</label>
        </div>
        <div class="login-check">
            <input type="checkbox" id="remember-check" value="script">
            <label for="remember-check" class="check-label">remember me 🐾</label>
        </div>
        <div class="login-check">
            <input type="checkbox" id="done-check" value="script">
            <label for="done-check" class="check-label">done ✅</label>
        </div>
        <div class="login-paws">🐾🐾🐾</div>
        <button id="login-btn" disabled>🐾 enter the cat zone 🐾</button>
        <p id="login-error"></p>
        <p class="login-footer">only cat learners allowed 😺</p>
    </div>
</div>
