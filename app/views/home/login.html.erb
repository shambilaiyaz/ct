<!-- ct — login view -->

<!-- Login Modal -->
<div id="login-overlay">
    <div id="login-box">
        <h1 id="login-title">🐱 welcome to ct web 🐱</h1>
        <p class="login-sub">the cat zone awaits you...</p>
        <label for="login-user">whats your name human?</label>
        <input
            type="text"
            id="login-user"
            placeholder="type your name..."
            autocomplete="username"
        >
        <label for="login-email">whats your email?</label>
        <input
            type="email"
            id="login-email"
            placeholder="your email..."
            autocomplete="email"
        >

        <div class="login-check">
            <input type="checkbox" id="cat-learn-check" value="script">
            <label for="cat-learn-check" class="check-label">I want to learn about cats 😺</label>
        </div>
        <div class="login-check">
            <input type="checkbox" id="remember-check" value="script">
            <label for="remember-check" class="check-label">remember me 🐾</label>
        </div>
        <div class="login-check">
            <input type="checkbox" id="done-check" value="script">
            <label for="done-check" class="check-label">done ✅</label>
        </div>

        <form method="POST" action="/feedbacks">
            <input type="text" id="feedback-input" name="feedback[text]" placeholder="please give a feedback" style="width:100%;padding:10px 14px;font-size:1rem;border:2.5px solid #ff8c42;border-radius:12px;background:rgba(255,255,255,0.85);outline:none;box-sizing:border-box;">
            <input type="hidden" name="feedback[username]" id="feedback-username" value="">
            <button type="submit" style="margin-top:8px;padding:8px 20px;font-size:0.95rem;font-weight:bold;color:white;background:linear-gradient(135deg,#ff6b6b,#ff3c7f);border:none;border-radius:10px;cursor:pointer;">send feedback 🐾</button>
        </form>

        <script>
            (function() {
                var fu = document.getElementById("feedback-username");
                if (fu) {
                    var u = sessionStorage.getItem("ct_username");
                    if (u) fu.value = u;
                }

                var form = document.querySelector("form[action='/feedbacks']");
                if (form) {
                    form.addEventListener("submit", function(e) {
                        e.preventDefault();
                        var input = document.getElementById("feedback-input");
                        var text = input ? input.value.trim() : "";
                        if (!text) return;

                        var csrfToken = document.querySelector('meta[name="csrf-token"]');
                        var headers = {
                            "X-Requested-With": "XMLHttpRequest",
                            "Content-Type": "application/json",
                            "Accept": "application/json"
                        };
                        if (csrfToken) headers["X-CSRF-Token"] = csrfToken.getAttribute("content");

                        var data = {
                            feedback: {
                                text: text,
                                username: fu ? fu.value : ""
                            }
                        };

                        fetch("/feedbacks", {
                            method: "POST",
                            headers: headers,
                            credentials: "same-origin",
                            body: JSON.stringify(data)
                        }).then(function(res) {
                            if (res.ok) {
                                input.value = "";
                                input.placeholder = "feedback sent! 🐾";
                            } else {
                                input.placeholder = "error, try again";
                            }
                        }).catch(function() {
                            input.placeholder = "network error, try again";
                        });
                    });
                }
            })();
        </script>

        <div class="login-paws">🐾🐾🐾</div>
        <button id="login-btn" disabled>🐾 enter the cat zone 🐾</button>
        <p id="login-error"></p>
        <p class="login-footer">only cat learners allowed 😺</p>
    </div>
</div>
